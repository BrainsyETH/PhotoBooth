    <!-- Privacy -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_body">SnapCabin captures photos using your device camera. Photos are stored locally on your device and are never uploaded to external servers unless you explicitly choose to share them.\n\nThe QR code sharing feature runs a temporary local server on your WiFi network. No data leaves your local network.\n\nWe do not collect analytics, personal information, or usage data.\n\nFor questions, contact: support@snapcabin.app</string>
